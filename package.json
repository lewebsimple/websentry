{
  "name": "websentry",
  "version": "0.0.0",
  "description": "WebSentry is a declarative web crawling and extraction framework.",
  "author": "Pascal Martineau <pascal@lewebsimple.ca>",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "./dist/core/index.js",
  "types": "./dist/core/index.d.ts",
  "exports": {
    ".": {
      "default": "./dist/core/index.js",
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    },
    "./core": {
      "default": "./dist/core/index.js",
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm --sequential /build:.*/",
    "build:rolldown": "rolldown --config ./rolldown.config.ts",
    "build:types": "tsc"
  },
  "packageManager": "pnpm@10.28.0",
  "devDependencies": {
    "@types/node": "^25.2.1",
    "rolldown": "1.0.0-rc.3",
    "typescript": "^5.9.3"
  }
}