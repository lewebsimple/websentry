{
  "name": "websentry",
  "version": "0.0.0",
  "description": "WebSentry is a declarative web crawling and extraction framework.",
  "homepage": "https://github.com/lewebsimple/websentry#readme",
  "bugs": {
    "url": "https://github.com/lewebsimple/websentry/issues"
  },
  "license": "AGPL-3.0-only",
  "author": "Pascal Martineau <pascal@lewebsimple.ca>",
  "repository": {
    "type": "git",
    "url": "https://github.com/lewebsimple/websentry.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/core/index.js",
  "types": "./dist/core/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "default": "./dist/core/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "default": "./dist/core/index.js"
    }
  },
  "scripts": {
    "build": "pnpm --sequential /build:.*/",
    "build:rolldown": "rolldown --config ./rolldown.config.ts",
    "build:types": "tsc",
    "format": "oxfmt .",
    "lint": "oxlint . --fix",
    "prepare": "husky",
    "release": "oxlint . && pnpm build && changelogen --noAuthors --release --push && pnpm publish --access public"
  },
  "devDependencies": {
    "@types/node": "^25.2.1",
    "changelogen": "^0.6.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "oxfmt": "^0.28.0",
    "oxlint": "^1.43.0",
    "rolldown": "1.0.0-rc.3",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{ts,json,md}": [
      "oxlint --fix",
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  },
  "packageManager": "pnpm@10.28.0",
  "changelog": {
    "types": {
      "chore": false
    }
  }
}
